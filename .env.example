# Notion Integration Token
# Get from: https://www.notion.so/my-integrations
# Must have access to the AI performance snapshot databases
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# n8n Instance
# Your self-hosted n8n URL (no trailing slash)
N8N_BASE_URL=https://n8n.sinaprinting.com
# n8n API key: Settings > API > Create API Key
N8N_API_KEY=your_n8n_api_key_here

# ClickUp API Key
# Get from: ClickUp > Profile > Apps > Generate API Token
CLICKUP_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Intercom Access Token (powers the FIN dashboard via live API instead of Notion)
# Get from: Intercom > Settings > Developers > Your apps > New app > Authentication
# Scopes required: "Read conversations"
INTERCOM_ACCESS_TOKEN=dG9rOjx5b3VyLWludGVyY29tLXRva2VuPjox

# ElevenLabs API Key (powers the ElevenLabs call dashboard via live API)
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API Key (optional — powers AI insights on the Overview page)
# Without this, the dashboard falls back to heuristic recommendations.
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
